{
  "name": "ekonstat-api",
  "version": "1.0.0",
  "description": "Tool for consolidating economic and financial data in Macedonia",
  "homepage": "https://github.com/nkvtd/EkonStat-API#readme",
  "bugs": {
    "url": "https://github.com/nkvtd/EkonStat-API/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nkvtd/EkonStat-API.git"
  },
  "license": "MIT",
  "author": "nkvtd",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "rimraf dist && node esbuild.config.js && tsc-alias",
    "dev:app": "tsx watch src/app.ts",
    "dev:scheduler": "tsx watch src/scheduler.worker.ts",
    "dev:backfiller": "tsx watch src/backfiller.worker.ts",
    "start:app": "node dist/app.js",
    "start:scheduler": "node dist/scheduler.worker.js",
    "start:backfiller": "node dist/backfiller.worker.js",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "db:generate": "drizzle-kit generate --config=./drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=./drizzle.config.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.11",
    "@hono/zod-validator": "^0.9.0",
    "@redtea/format-axios-error": "^2.1.1",
    "axios": "^1.18.1",
    "axios-cookiejar-support": "^6.0.5",
    "croner": "^10.0.1",
    "cronstrue": "^3.24.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.31",
    "hono-rate-limiter": "^0.5.3",
    "p-map": "^7.0.6",
    "p-queue": "^9.3.2",
    "pg": "^8.22.0",
    "tough-cookie": "^6.0.2",
    "tsc-alias": "^1.9.1",
    "winston": "^3.19.0",
    "zod": "^4.4.3",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@types/node": "^26.1.1",
    "@types/p-map": "^2.0.0",
    "@types/pg": "^8.20.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  },
  "keywords": [],
  "overrides": {
    "esbuild": "^0.25.0"
  }
}
